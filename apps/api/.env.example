# ─── Denimisia API — environment reference ──────────────────────────────────
# Copy this to `.env` and fill in real values. NEVER commit .env.
# Every variable listed here is REQUIRED unless noted otherwise.

# App
NODE_ENV=development                  # development | test | production
PORT=3001

# Allowed browser origins (comma-separated). Storefront + admin.
# Production: set to your real domains.
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── Database (Supabase Postgres or any Postgres 14+) ──────────────────────
# Pooler in transaction mode (port 6543) for runtime queries.
DATABASE_URL=postgresql://user:pass@host:6543/postgres?sslmode=require&pgbouncer=true
# Pooler in session mode (port 5432) for Prisma migrations only - transaction
# mode rejects the advisory locks migrate needs. Same credentials, port 5432.
DIRECT_URL=postgresql://user:pass@host:5432/postgres?sslmode=require

# ─── Redis (sessions + cache) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=                    # >= 64 chars random
JWT_REFRESH_SECRET=                   # >= 64 chars random, different from access
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Google OAuth (server-side ID-token verification) ──────────────────────
# Same OAuth 2.0 Client ID used by the web app's AUTH_GOOGLE_ID. The API
# verifies that the id_token's `aud` claim equals this value before trusting
# the Google-issued email. Leave blank to disable Google sign-in entirely
# (the /auth/oauth/google endpoint will return 401).
GOOGLE_CLIENT_ID=

# ─── Cloudflare R2 (object storage) ────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=denimisia-media
R2_PUBLIC_URL=https://cdn.denimisia.com    # the CDN domain in front of R2

# ─── Supabase Storage (legacy — kept while media migration to R2 is pending) ─
# Leave blank if you're fully on R2.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_ORIGINALS=media-originals
SUPABASE_BUCKET_PUBLIC=media-public

# ─── Algolia (product search — optional) ────────────────────────────────────
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_SEARCH_KEY=
ALGOLIA_INDEX_NAME=products

# ─── Rate limiting ─────────────────────────────────────────────────────────
# Global default applies to anonymous traffic. Auth endpoints override with
# tighter rules in the module itself — see auth.controller.ts.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60

# ─── Initial SUPER_ADMIN (used by packages/database prod:cleanup only) ──────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ─── Resend (transactional email — Phase 0 wiring) ──────────────────────────
# Get the API key from https://resend.com/api-keys
RESEND_API_KEY=
# The "from" address must be on a Resend-verified domain in production.
# For sandbox / dev work, Resend's onboarding flow exposes a default address.
RESEND_FROM_EMAIL=noreply@denimisia.example
RESEND_FROM_NAME=Denimisia

# Storefront URL — used to build links inside transactional emails.
# Production: set to your real https customer-facing domain (no trailing slash).
STOREFRONT_URL=http://localhost:3000
