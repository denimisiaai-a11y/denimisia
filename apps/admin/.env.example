# ─── Denimisia Admin (dashboard) — environment reference ────────────────────
# Copy this to `apps/admin/.env` and fill in real values. NEVER commit .env.

# ─── API ─────────────────────────────────────────────────────────────────────
# The NestJS API base URL, including /api/v1.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Customer storefront origin (used by the CMS preview iframe to drive the
# WYSIWYG slot editor through postMessage).
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_SECRET=
# Production: set to your admin-facing https URL.
NEXTAUTH_URL=http://localhost:3002

# Sentry was considered but dropped from launch scope 2026-05-17.
