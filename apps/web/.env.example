# ─── Denimisia Web (customer storefront) — environment reference ──────────────
# Copy this to `apps/web/.env` and fill in real values. NEVER commit .env.
# Anything prefixed with NEXT_PUBLIC_ is bundled into the client and is NOT a
# secret. Anything without that prefix is server-only.

# ─── API ─────────────────────────────────────────────────────────────────────
# The NestJS API base URL, including /api/v1.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Admin app origin (used by slot-draft-listener for the CMS edit-mode iframe
# postMessage handshake). Comma-separated if multiple.
NEXT_PUBLIC_ADMIN_ORIGINS=http://localhost:3002

# ─── Site identity ───────────────────────────────────────────────────────────
# Public canonical site URL used by SEO + sitemap generators.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
NEXTAUTH_SECRET=
# Production: set to your customer-facing https URL.
NEXTAUTH_URL=http://localhost:3000

# ─── R2 public CDN ───────────────────────────────────────────────────────────
# Public URL prefix for R2-served images. Must match the R2_PUBLIC_URL in the
# API .env. Used by lib/image.ts to rewrite image paths.
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-39d4f51379c0476098b5292730f14b86.r2.dev

# ─── SEO meta verification (optional — leave blank to skip the meta tag) ─────
GOOGLE_SITE_VERIFICATION=
META_DOMAIN_VERIFICATION=

# ─── Analytics + ads pixels (optional — Phase 5 work) ────────────────────────
# Without these set, the corresponding scripts/tags don't render.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# ─── Sentry (Phase 5 — not currently active) ─────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=

# ─── Plausible (Phase 5 — not currently active) ──────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
